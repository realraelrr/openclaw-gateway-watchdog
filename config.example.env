# OpenClaw Gateway Watchdog config example
# Precedence: process env > WATCHDOG_ENV_FILE > defaults
#
# Leave path overrides blank to use the default $HOME/.openclaw layout.
# Values in this file are parsed as literal key=value pairs; shell expansion is not performed.

# Optional path overrides
OPENCLAW_HOME=
WATCHDOG_STATE_DIR=
WATCHDOG_LOG_DIR=
WATCHDOG_ENV_FILE=
WATCHDOG_DISABLE_FILE=

# Runtime behavior
NOTIFIER=composite
FAIL_THRESHOLD=3
COOLDOWN_SEC=300
POST_RESTART_RETRIES=3
POST_RESTART_SLEEP_SEC=5

# Optional runtime overrides
OPENCLAW_BIN=
NODE_BIN=
WATCHDOG_ENABLED=1

# Optional webhook targets
DISCORD_WATCHDOG_WEBHOOK_URL=
FEISHU_WATCHDOG_WEBHOOK_URL=
