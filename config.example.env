# Gateway Watchdog config example
# Precedence: process env > WATCHDOG_ENV_FILE > defaults

NOTIFIER=composite
FAIL_THRESHOLD=3
COOLDOWN_SEC=300
POST_RESTART_RETRIES=3
POST_RESTART_SLEEP_SEC=5
PROBE_CONFIRM_SLEEP_SEC=2
WATCHDOG_ENV_FILE=/Users/rael/.openclaw/config/watchdog.env

# Optional runtime overrides
OPENCLAW_BIN=
NODE_BIN=
WATCHDOG_ENABLED=1
WATCHDOG_DISABLE_FILE=/Users/rael/.openclaw/.state/runtime/gateway_watchdog.disabled

# Optional webhook targets
DISCORD_WATCHDOG_WEBHOOK_URL=
FEISHU_WATCHDOG_WEBHOOK_URL=
