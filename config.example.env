# OpenClaw Gateway Watchdog config example
# Precedence: process env > WATCHDOG_ENV_FILE > defaults
#
# Leave path overrides blank to use the default $HOME/.openclaw layout.
# Values in this file are parsed as literal key=value pairs; shell expansion is not performed.

# Optional path overrides
OPENCLAW_HOME=
WATCHDOG_STATE_DIR=
WATCHDOG_LOG_DIR=
WATCHDOG_ENV_FILE=
WATCHDOG_DISABLE_FILE=

# Runtime behavior
NOTIFIER=composite
WATCHDOG_DISPLAY_NAME=OpenClaw Gateway Watchdog
FAIL_THRESHOLD=3
MAX_RESTART_FAILURES=10
COOLDOWN_SEC=300
POST_RESTART_RETRIES=3
POST_RESTART_SLEEP_SEC=5

# Optional runtime overrides
OPENCLAW_BIN=
NODE_BIN=
WATCHDOG_ENABLED=1

# Optional notification targets
DISCORD_WATCHDOG_WEBHOOK_URL=
FEISHU_BOT_APP_ID=
FEISHU_BOT_APP_SECRET=
FEISHU_BOT_CHAT_ID=
FEISHU_BOT_RECEIVE_ID_TYPE=chat_id
FEISHU_BOT_API_BASE=https://open.feishu.cn/open-apis
